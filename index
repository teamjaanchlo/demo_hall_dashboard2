<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Wedding Hall Management Dashboard</title>

  <!-- Tailwind Play CDN (production میں build version استعمال کریں) -->
  <script src="https://cdn.tailwindcss.com?plugins=forms,typography,aspect-ratio"></script>

  <!-- Tailwind custom config -->
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            background: '#0A0A0A',
            card: '#111111',
            primary: '#D4AF37',      // gold
            'primary-100': '#F2E8C3',
            'primary-500': '#D4AF37',
            'primary-600': '#C0A000',
          },
        },
        fontFamily: {
          sans: ['"Inter"', 'sans-serif']
        }
      }
    }
  </script>

  <style type="text/tailwindcss">
    @layer utilities {
      .glass {
        @apply backdrop-blur-md bg-white/10 border border-primary/30;
      }
      .btn-gold {
        @apply bg-primary text-background hover:bg-primary-600 transition-colors;
      }
      .stat-card {
        @apply glass rounded-xl border border-primary/20 hover:shadow-lg transition-shadow;
      }
    }
  </style>
</head>
<body class="bg-background text-foreground min-h-screen font-sans">

  <!-- Login Screen -->
  <div id="login-screen" class="fixed inset-0 flex items-center justify-center z-50">
    <div class="absolute inset-0 bg-black/80"></div>
    <div class="relative z-10 max-w-md w-full m-4">
      <div class="glass p-6 rounded-2xl space-y-4">
        <h1 class="text-2xl font-bold text-center text-primary-100">Wedding Hall Management</h1>
        <p class="text-sm text-gray-300 text-center">Admin & Staff Login Panel</p>

        <div class="space-y-3">
          <input
            type="text"
            placeholder="Email / Username"
            class="w-full px-4 py-2 bg-black/40 border border-primary/30 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:border-primary"
          />
          <input
            type="password"
            placeholder="Password"
            class="w-full px-4 py-2 bg-black/40 border border-primary/30 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:border-primary"
          />
          <div class="flex items-center justify-between text-sm text-gray-300">
            <label class="flex items-center gap-1 cursor-pointer">
              <input type="checkbox" class="text-primary" /> Remember me
            </label>
            <a href="#" class="text-primary hover:underline">Forgot Password?</a>
          </div>
        </div>

        <div class="flex gap-3 pt-2">
          <button
            onclick="showDashboard()"
            class="btn-gold px-6 py-2 rounded-lg font-medium flex-1"
          >
            Admin Login
          </button>
          <button
            onclick="showDashboard()"
            class="px-6 py-2 rounded-lg font-medium border border-primary-600 text-primary-100 hover:bg-primary/20"
          >
            Staff Login
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Dashboard (starts hidden) -->
  <div id="dashboard" class="hidden flex flex-col h-screen">

    <!-- Top Navbar -->
    <nav class="flex items-center justify-between p-4 bg-card border-b border-primary/20">
      <h1 class="text-xl font-bold text-primary-100">Wedding Hall Dashboard</h1>
      <div class="flex items-center gap-3">
        <button class="px-3 py-1 text-xs rounded bg-primary/20 text-primary hover:bg-primary/30">
          PKR 2.75M Revenue
        </button>
        <button id="dark-mode-toggle" class="text-sm text-gray-400 hover:text-primary">
          Light Mode
        </button>
      </div>
    </nav>

    <!-- Sidebar -->
    <div class="flex flex-1 overflow-hidden">
      <aside class="w-64 bg-card border-r border-primary/20 p-4 space-y-4 hidden md:block">
        <div class="space-y-2">
          <a href="#" class="block py-2 px-3 rounded hover:bg-primary/20 text-primary-100 font-medium">
            Dashboard
          </a>
          <a href="#" class="block py-2 px-3 rounded hover:bg-primary/20 text-primary-100">
            Bookings
          </a>
          <a href="#" class="block py-2 px-3 rounded hover:bg-primary/20 text-primary-100">
            Calendar
          </a>
          <a href="#" class="block py-2 px-3 rounded hover:bg-primary/20 text-primary-100">
            Payments
          </a>
          <a href="#" class="block py-2 px-3 rounded hover:bg-primary/20 text-primary-100">
            Customers
          </a>
          <a href="#" class="block py-2 px-3 rounded hover:bg-primary/20 text-primary-100">
            Staff
          </a>
          <a href="#" class="block py-2 px-3 rounded hover:bg-primary/20 text-primary-100">
            Expenses
          </a>
          <a href="#" class="block py-2 px-3 rounded hover:bg-primary/20 text-primary-100">
            Reports
          </a>
          <a href="#" class="block py-2 px-3 rounded hover:bg-primary/20 text-primary-100">
            Settings
          </a>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 p-4 space-y-6 overflow-y-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-4">
          <!-- Stat Card 1 -->
          <div class="stat-card p-4">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs text-gray-400">Total Bookings</p>
                <p class="text-xl font-bold">128</p>
                <p class="text-green-400 text-xs flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="18 15 12 9 6 15"></polyline></svg>
                  12%
                </p>
              </div>
              <div class="p-2 rounded-full bg-primary/20 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 2H9a5 5 0 0 0-5 5v12a5 5 0 0 0 5 5h6a5 5 0 0 0 5-5V7a5 5 0 0 0-5-5Z"></path><path d="M9 16v-6h6v6"></path></svg>
              </div>
            </div>
          </div>

          <!-- Stat Card 2 -->
          <div class="stat-card p-4">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs text-gray-400">Total Revenue</p>
                <p class="text-xl font-bold">PKR 2.75M</p>
                <p class="text-green-400 text-xs flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="18 15 12 9 6 15"></polyline></svg>
                  8.2%
                </p>
              </div>
              <div class="p-2 rounded-full bg-primary/20 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
              </div>
            </div>
          </div>

          <!-- Stat Card 3 -->
          <div class="stat-card p-4">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs text-gray-400">Pending Payments</p>
                <p class="text-xl font-bold">PKR 320K</p>
                <p class="text-red-400 text-xs flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="18 9 12 15 6 9"></polyline></svg>
                  3.1%
                </p>
              </div>
              <div class="p-2 rounded-full bg-primary/20 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 5H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2Z"></path><path d="M8 17v-2"></path><path d="M12 17v-4"></path><path d="M16 17v-6"></path></svg>
              </div>
            </div>
          </div>

          <!-- Stat Card 4 -->
          <div class="stat-card p-4">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs text-gray-400">Upcoming Events</p>
                <p class="text-xl font-bold">14</p>
                <p class="text-green-400 text-xs flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="18 15 12 9 6 15"></polyline></svg>
                  5.5%
                </p>
              </div>
              <div class="p-2 rounded-full bg-primary/20 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
              </div>
            </div>
          </div>

          <!-- Stat Card 5 -->
          <div class="stat-card p-4">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs text-gray-400">Today's Events</p>
                <p class="text-xl font-bold">3</p>
              </div>
              <div class="p-2 rounded-full bg-primary/20 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              </div>
            </div>
          </div>

          <!-- Stat Card 6 -->
          <div class="stat-card p-4">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs text-gray-400">Total Customers</p>
                <p class="text-xl font-bold">96</p>
                <p class="text-green-400 text-xs flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="18 15 12 9 6 15"></polyline></svg>
                  6.8%
                </p>
              </div>
              <div class="p-2 rounded-full bg-primary/20 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
              </div>
            </div>
          </div>
        </div>

        <!-- Charts & Sidebar Right -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <div class="lg:col-span-2 space-y-6">
            <div class="stat-card p-4">
              <h3 class="font-medium text-primary-100 mb-3">Monthly Revenue</h3>
              <div class="h-48 flex items-end justify-between gap-1">
                <div class="flex-1 bg-primary/50 rounded-t opacity-80 h-28"></div>
                <div class="flex-1 bg-primary/50 rounded-t opacity-90 h-32"></div>
                <div class="flex-1 bg-primary/50 rounded-t opacity-70 h-24"></div>
                <div class="flex-1 bg-primary/50 rounded-t opacity-100 h-36"></div>
                <div class="flex-1 bg-primary/50 rounded-t opacity-80 h-30"></div>
                <div class="flex-1 bg-primary/50 rounded-t opacity-70 h-26"></div>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="stat-card p-4">
                <h3 class="font-medium text-primary-100 mb-3">Booking Trends</h3>
                <div class="h-32 flex items-center justify-center text-gray-400">Line Chart Placeholder</div>
              </div>
              <div class="stat-card p-4">
                <h3 class="font-medium text-primary-100 mb-3">Hall Popularity</h3>
                <div class="h-32 flex items-center justify-center text-gray-400">Pie Chart Placeholder</div>
              </div>
            </div>
          </div>

          <div class="space-y-4">
            <!-- Recent Payments -->
            <div class="stat-card p-3">
              <h4 class="font-medium text-primary-100 mb-2">Recent Payments</h4>
              <div class="space-y-2 text-sm">
                <div class="flex justify-between">
                  <span>Ayesha & Ali</span>
                  <span class="text-green-400">+PKR 60,000</span>
                </div>
                <div class="flex justify-between">
                  <span>Zara & Talha</span>
                  <span class="text-green-400">+PKR 12,000</span>
                </div>
              </div>
            </div>

            <!-- Upcoming Events -->
            <div class="stat-card p-3">
              <h4 class="font-medium text-primary-100 mb-2">Upcoming Events</h4>
              <div class="space-y-2 text-sm">
                <div class="flex justify-between">
                  <span>Ayesha & Ali</span>
                  <span class="text-gray-400">15 Jun</span>
                </div>
                <div class="flex justify-between">
                  <span>Zara & Talha</span>
                  <span class="text-gray-400">02 Jul</span>
                </div>
              </div>
            </div>

            <!-- Notifications -->
            <div class="stat-card p-3">
              <h4 class="font-medium text-primary-100 mb-2">Notifications</h4>
              <div class="space-y-1 text-xs text-gray-400">
                <div>Payment reminder for BK-1001</div>
                <div>Hall cleaning scheduled tomorrow</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Bookings Table -->
        <div class="stat-card p-4">
          <h3 class="font-medium text-primary-100 mb-4">Recent Bookings</h3>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="text-gray-400">
                  <th class="text-left pb-2">Booking ID</th>
                  <th class="text-left pb-2">Customer</th>
                  <th class="text-left pb-2">Event Date</th>
                  <th class="text-left pb-2">Hall</th>
                  <th class="text-right pb- حقیقی Guests</th>
                  <th class="text-right pb-2">Total</th>
                  <th class="text-right pb-2">Status</th>
                  <th class="text-right pb-2">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-primary/20">
                <tr class="hover:bg-primary/10">
                  <td class="py-2">BK-1001</td>
                  <td class="py-2">Ayesha & Ali</td>
                  <td class="py-2">15 Jun 2026</td>
                  <td class="py-2">Grand Sapphire Hall</td>
                  <td class="py-2 text-right">450</td>
                  <td class="py-2 text-right">PKR 850,000</td>
                  <td class="py-2 text-right">
                    <span class="px-2 py-1 rounded-full bg-yellow-500/30 text-yellow-300 text-xs">Partial</span>
                  </td>
                  <td class="py-2 text-right">
                    <button class="text-sm text-primary-100 hover:underline mx-1">View</button>
                    <button class="text-sm text-primary-100 hover:underline mx-1">Edit</button>
                  </td>
                </tr>
                <tr class="hover:bg-primary/10">
                  <td class="py-2">BK-1002</td>
                  <td class="py-2">Zara & Talha</td>
                  <td class="py-2">02 Jul 2026</td>
                  <td class="py-2">Crystal Rose Hall</td>
                  <td class="py-2 text-right">600</td>
                  <td class="py-2 text-right">PKR 1,200,000</td>
                  <td class="py-2 text-right">
                    <span class="px-2 py-1 rounded-full bg-green-500/30 text-green-300 text-xs">Paid</span>
                  </td>
                  <td class="py-2 text-right">
                    <button class="text-sm text-primary-100 hover:underline mx-1">View</button>
                    <button class="text-sm text-primary-100 hover:underline mx-1">Edit</button>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </main>
    </div>
  </div>

  <!-- JavaScript -->
  <script>
    function showDashboard() {
      document.getElementById("login-screen").style.display = "none";
      document.getElementById("dashboard").classList.remove("hidden");
    }

    document.getElementById("dark-mode-toggle").addEventListener("click", () => {
      const darkMode = document.documentElement.classList.toggle("dark");
      this.textContent = darkMode ? "Light Mode" : "Dark Mode";
    });
  </script>
</body>
</html>
